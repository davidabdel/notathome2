# Not At Home v2 — Environment Variables
# Copy this to .env.local and fill in values

# Neon Postgres — get connection string from neon.tech dashboard
DATABASE_URL=postgresql://user:password@ep-xxx.neon.tech/nothome?sslmode=require

# JWT secret — generate with: openssl rand -base64 32
JWT_SECRET=your-32-char-secret-here

# Super admin credentials (your login for /admin-login)
SUPER_ADMIN_EMAIL=david@uconnect.com.au
SUPER_ADMIN_PASSWORD=your-super-admin-password

# Email (SMTP) — Resend free tier recommended (3k emails/month free)
# Sign up at resend.com, get API key, use smtp.resend.com
SMTP_HOST=smtp.resend.com
SMTP_PORT=587
SMTP_USER=resend
SMTP_PASS=re_your_api_key_here
SMTP_FROM=noreply@nothome.app

# Cron job secret — random string to secure /api/cron/expire-sessions
CRON_SECRET=your-random-cron-secret-here 